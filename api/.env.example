DATABASE_URL=postgresql+psycopg2://gulp:gulp@localhost:5432/gulp_marketplace
POSTGRES_DB=gulp_marketplace
POSTGRES_USER=gulp
POSTGRES_PASSWORD=gulp
CORS_ORIGINS=http://localhost:3000

# Auth — override JWT_SECRET in every non-dev environment.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=604800

# Cookie flags — set COOKIE_SECURE=true and COOKIE_SAMESITE=none in prod
# when the web + API live on different parent domains over HTTPS.
COOKIE_NAME=gulp_auth
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Coin flip QA: clear buyer reveal stamps on every API boot (localhost dev).
# Set false in production. ``python seed.py`` also clears them after each run.
RESET_FLIP_BUYER_VIEWS_ON_BOOT=true
